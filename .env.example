# 1. Copy this file:  cp .env.example .env
# 2. Create a DEDICATED Gmail account for SnoozeNot (not your personal Gmail)
#    - Example: snoozenot.reminders@gmail.com
#    - Upload your SnoozeNot logo as the Google profile photo
#    - Enable 2FA, then create an App Password: https://myaccount.google.com/apppasswords
# 3. Put that account in EMAIL_HOST_USER / EMAIL_HOST_PASSWORD below
# 4. Set REMINDER_FROM_EMAIL to the same dedicated Gmail address
# 5. Restart the dev server
#
# Why not personal Gmail?
# Gmail SMTP always sends as the logged-in account. Your personal profile photo
# and email address will appear to recipients — changing From to noreply@... is ignored.
#
# Without .env configured, reminders only print in the Django terminal — not your inbox.
#
# Avoiding spam folder (best → good):
# 1. Use a dedicated sending Gmail (above), not your personal account
# 2. Log into the sending Gmail in a browser and send a normal email once
# 3. Recipients: open one reminder → "Not spam" → add sender to contacts
# 4. Production: use your own domain with SPF/DKIM via Google Workspace,
#    SendGrid, Resend, or Mailgun — Gmail-to-Gmail from a new account often
#    lands in spam until the sender builds reputation

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=snoozenot.reminders@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=SnoozeNot <snoozenot.reminders@gmail.com>
REMINDER_FROM_EMAIL=SnoozeNot <snoozenot.reminders@gmail.com>
REMINDER_REPLY_TO=snoozenot.reminders@gmail.com
SITE_URL=http://127.0.0.1:8000
TIME_ZONE=Africa/Lagos
